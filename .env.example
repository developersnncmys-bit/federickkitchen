# Copy to .env.local and fill in. None of these are required to run the site
# locally — without them, emails print to the server log instead of sending.

# --- Admin panel (/admin) -------------------------------------------------
# The password the house staff type in. Pick something long.
ADMIN_PASSWORD=change-me-before-going-live
# Signs the session cookie. Generate with: openssl rand -hex 32
# Required in production — the build will refuse to start without it.
ADMIN_SECRET=

# --- Email confirmations --------------------------------------------------
# From resend.com. Leave blank and every email is logged, not sent.
RESEND_API_KEY=
# Must be a verified domain on the Resend account once live.
BOOKING_FROM="Frederick's Kitchen <stay@frederickskitchen.in>"

# --- Analytics (Module 09) ------------------------------------------------
# GA4 measurement ID, e.g. G-XXXXXXXXXX. Omit and no script is loaded at all.
NEXT_PUBLIC_GA_ID=
# The content= value from the Search Console HTML-tag verification method.
NEXT_PUBLIC_GSC_VERIFICATION=
